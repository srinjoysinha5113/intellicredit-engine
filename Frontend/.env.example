# API Configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_API_ENDPOINT=/api/chat
VITE_API_STREAM_ENDPOINT=/api/chat/stream

# Application Configuration
VITE_APP_NAME=Jindal Operations Assistant
VITE_APP_VERSION=2.0.0

# Development Configuration
VITE_DEV_MODE=true
VITE_DEBUG=false

# FAQ Configuration
VITE_FAQ_DATA_PATH=/data/faq_data.json

# Session Configuration
VITE_SESSION_STORAGE=sessionStorage
VITE_CHAT_HISTORY_KEY=chatHistory
VITE_DRAFT_INPUT_KEY=draftInput
VITE_SESSION_ID_KEY=sessionId
VITE_CURRENT_VIEW_KEY=currentView
VITE_PROCESSING_KEY=isProcessing

# UI Configuration
VITE_MOBILE_BREAKPOINT=768
VITE_MAX_MESSAGE_LENGTH=1000

# API Timeout Configuration
VITE_API_TIMEOUT=30000
VITE_RETRY_ATTEMPTS=3
